{
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    // Required for the `@site/*` path alias to resolve. TypeScript 7 will
    // deprecate `baseUrl`; the replacement belongs in @docusaurus/tsconfig,
    // and setting "ignoreDeprecations" here is rejected by TypeScript 5.7.
    "baseUrl": "."
  },
  "exclude": [
    "build",
    ".docusaurus",
    "node_modules",
    "versioned_docs"
  ]
}
