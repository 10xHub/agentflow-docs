{
  "name": "agentflow-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Professional documentation site for AgentFlow.",
  "scripts": {
    "start": "NO_UPDATE_NOTIFIER=1 docusaurus clear && NO_UPDATE_NOTIFIER=1 docusaurus start",
    "build": "NO_UPDATE_NOTIFIER=1 docusaurus build",
    "serve": "NO_UPDATE_NOTIFIER=1 docusaurus serve",
    "clear": "NO_UPDATE_NOTIFIER=1 docusaurus clear",
    "typecheck": "tsc --noEmit",
    "seo:audit": "node scripts/audit-frontmatter.mjs",
    "seo:fix": "node scripts/fix-frontmatter.mjs",
    "seo:og-image": "node scripts/generate-og-image.mjs"
  },
  "dependencies": {
    "@docusaurus/core": "^3.8.1",
    "@docusaurus/plugin-client-redirects": "^3.9.2",
    "@docusaurus/preset-classic": "^3.8.1",
    "@docusaurus/theme-mermaid": "^3.8.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@mdx-js/react": "^3.1.0",
    "lucide-react": "^1.14.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.8.1",
    "@docusaurus/tsconfig": "^3.8.1",
    "@docusaurus/types": "^3.8.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "~5.7.2"
  },
  "engines": {
    "node": ">=20.0"
  }
}
